# ============================================================
# OmniTrade AI — Multi-Asset Autonomous Trading System
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Exchange (Bybit) ---
# Public API works without keys for OHLCV/orderbook/ticker.
# Add keys for live trading only.
EXCHANGE_NAME=bybit
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_SANDBOX_MODE=false

# --- Database (MongoDB) ---
DB_URI=mongodb://localhost:27017
DB_NAME=omnitrade

# --- Stock Trading (Alpaca Markets) ---
STOCK_ALPACA_API_KEY=your_alpaca_api_key
STOCK_ALPACA_API_SECRET=your_alpaca_api_secret
STOCK_ALPACA_PAPER=true

# --- Sports Betting (The Odds API) ---
BETTING_ODDS_API_KEY=your_odds_api_key

# --- Sentiment / Social APIs ---
SENTIMENT_REDDIT_CLIENT_ID=your_reddit_client_id
SENTIMENT_REDDIT_CLIENT_SECRET=your_reddit_client_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
NEWS_API_KEY=your_newsapi_key

# --- On-Chain Data ---
ALCHEMY_API_KEY=your_alchemy_api_key
GLASSNODE_API_KEY=your_glassnode_api_key

# --- Macro Data ---
FRED_API_KEY=your_fred_api_key

# --- Monitoring ---
MONITORING_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
MONITORING_TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Trading Parameters (override defaults) ---
# TRADING_MAX_POSITION_SIZE=0.10
# TRADING_STOP_LOSS=0.02
# TRADING_TAKE_PROFIT=0.04
# TRADING_MAX_DAILY_DRAWDOWN=0.05
# TRADING_MAX_OPEN_TRADES=3

# --- Asset Selection ---
# ASSET_ENABLED_ASSETS=["crypto","stock","bet"]
