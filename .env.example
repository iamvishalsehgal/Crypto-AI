# ============================================================
# AI Crypto Trading Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Exchange (Binance) ---
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_API_SECRET=your_binance_api_secret_here
EXCHANGE_SANDBOX_MODE=true

# --- Database (MongoDB) ---
DB_URI=mongodb://localhost:27017
DB_NAME=crypto_bot

# --- Sentiment / Social APIs ---
SENTIMENT_REDDIT_CLIENT_ID=your_reddit_client_id
SENTIMENT_REDDIT_CLIENT_SECRET=your_reddit_client_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
NEWS_API_KEY=your_newsapi_key

# --- On-Chain Data ---
ALCHEMY_API_KEY=your_alchemy_api_key
GLASSNODE_API_KEY=your_glassnode_api_key

# --- Macro Data ---
FRED_API_KEY=your_fred_api_key

# --- Monitoring ---
MONITORING_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
MONITORING_TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Trading Parameters (override defaults) ---
# TRADING_MAX_POSITION_SIZE=0.10
# TRADING_STOP_LOSS=0.02
# TRADING_TAKE_PROFIT=0.04
# TRADING_MAX_DAILY_DRAWDOWN=0.05
# TRADING_MAX_OPEN_TRADES=3

# --- Safety Guardrails (override defaults) ---
# SAFETY_MAX_FEE_PER_TRADE_PCT=0.002      # Max fee as % of trade (0.2%)
# SAFETY_MAX_DAILY_FEES=50.0              # Hard cap on daily fees in USD
# SAFETY_MIN_PROFIT_AFTER_FEES=0.005      # Min expected profit after fees (0.5%)
# SAFETY_RESERVE_BALANCE_PCT=0.20         # 20% balance is NEVER traded
# SAFETY_MIN_TRADE_SIZE_USD=10.0          # Minimum trade size
# SAFETY_MIN_BALANCE_TO_TRADE=100.0       # Stop trading below this balance
# SAFETY_COOLDOWN_AFTER_TRADE_SEC=30      # Seconds between trades per symbol
# SAFETY_COOLDOWN_AFTER_LOSS_SEC=120      # Extra cooldown after a loss
# SAFETY_MAX_TRADES_PER_HOUR=10           # Rate limit per hour
# SAFETY_MAX_TRADES_PER_DAY=50            # Rate limit per day
# SAFETY_MAX_DATA_AGE_SEC=300             # Reject data older than 5 min
# SAFETY_MAX_ATR_MULTIPLIER=3.0           # Skip in extreme volatility
# SAFETY_KILL_ON_CONSECUTIVE_LOSSES=5     # Kill switch: N losses in a row
# SAFETY_KILL_ON_EQUITY_DROP_PCT=0.15     # Kill switch: 15% equity drop from peak
